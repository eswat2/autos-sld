{
  "name": "autos-sld",
  "version": "0.0.1441",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "spell": "cspell *.{html,json,js,md,ts} src/*.{css,tsx}",
    "cc": "prettier --check src",
    "format": "prettier --write src",
    "open": "open https://autos-sld.vercel.app"
  },
  "dependencies": {
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "fetchql": "3.0.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.500",
    "tailwindcss": "4.3.0",
    "vite": "8.0.16",
    "vite-plugin-solid": "2.11.12",
    "yoctocolors": "2.1.2"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
