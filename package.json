{
  "name": "autos-sld",
  "version": "0.0.1459",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "spell": "cspell *.{html,json,js,md,ts} src/*.{css,tsx}",
    "cc": "prettier --check src",
    "format": "prettier --write src",
    "open": "open https://autos-sld.vercel.app"
  },
  "dependencies": {
    "solid-js": "1.9.13"
  },
  "devDependencies": {
    "autoprefixer": "10.5.2",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "fetchql": "3.0.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.510",
    "tailwindcss": "4.3.1",
    "vite": "8.1.0",
    "vite-plugin-solid": "2.11.12",
    "yoctocolors": "2.1.2"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
