{
  "name": "autos-sld",
  "version": "0.0.1474",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "spell": "cspell *.{html,json,js,md,ts} src/*.{css,tsx}",
    "cc": "prettier --check src",
    "format": "prettier --write src",
    "open": "open https://autos-sld.vercel.app"
  },
  "dependencies": {
    "solid-js": "1.9.14"
  },
  "devDependencies": {
    "autoprefixer": "10.5.2",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "fetchql": "3.0.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.513",
    "tailwindcss": "4.3.2",
    "vite": "8.1.4",
    "vite-plugin-solid": "2.11.12",
    "yoctocolors": "2.1.2"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
